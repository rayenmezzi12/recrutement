services:
  postgres:
    image: postgres:16-alpine
    container_name: pfa-postgres
    environment:
      POSTGRES_USER: ${SPRING_DATASOURCE_USERNAME:-postgres}
      POSTGRES_PASSWORD: ${SPRING_DATASOURCE_PASSWORD:-postgres}
    ports:
      - "5433:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
      - ./docker/postgres/init.sql:/docker-entrypoint-initdb.d/init.sql:ro
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U postgres"]
      interval: 5s
      timeout: 5s
      retries: 10
    restart: unless-stopped

  rabbitmq:
    image: rabbitmq:3-management-alpine
    container_name: pfa-rabbitmq
    ports:
      - "5672:5672"
      - "15672:15672"
    environment:
      RABBITMQ_DEFAULT_USER: ${SPRING_RABBITMQ_USERNAME:-guest}
      RABBITMQ_DEFAULT_PASS: ${SPRING_RABBITMQ_PASSWORD:-guest}
    healthcheck:
      test: ["CMD", "rabbitmq-diagnostics", "ping"]
      interval: 10s
      timeout: 5s
      retries: 10
    restart: unless-stopped

  eureka-server:
    build: ./backend/eureka-server
    container_name: pfa-eureka
    ports:
      - "8761:8761"
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://localhost:8761/actuator/health || exit 1"]
      interval: 15s
      timeout: 5s
      retries: 8
      start_period: 30s
    restart: unless-stopped

  auth-service:
    build: ./backend/authentification
    container_name: pfa-auth
    depends_on:
      postgres:
        condition: service_healthy
      eureka-server:
        condition: service_healthy
    environment:
      SPRING_DATASOURCE_URL: jdbc:postgresql://postgres:5432/auth_db
      SPRING_DATASOURCE_USERNAME: ${SPRING_DATASOURCE_USERNAME:-postgres}
      SPRING_DATASOURCE_PASSWORD: ${SPRING_DATASOURCE_PASSWORD:-postgres}
      EUREKA_CLIENT_SERVICEURL_DEFAULTZONE: http://eureka-server:8761/eureka/
      EUREKA_INSTANCE_HOSTNAME: auth-service
      JAVA_TOOL_OPTIONS: "-Dfile.encoding=UTF-8"
      JWT_SECRET: ${JWT_SECRET:-9a4f2c8d3b7a1e5f8g6h4j2k0l9m8n7o6p5q4r3s2t1u0v9w8x7y6z5a4b3c2d1e}
    ports:
      - "8081:8081"
    restart: unless-stopped

  logique-metier-service:
    build: ./backend/logique-metier
    container_name: pfa-metier
    depends_on:
      postgres:
        condition: service_healthy
      rabbitmq:
        condition: service_healthy
      eureka-server:
        condition: service_healthy
    environment:
      SPRING_DATASOURCE_URL: jdbc:postgresql://postgres:5432/logique_metier_db
      SPRING_DATASOURCE_USERNAME: ${SPRING_DATASOURCE_USERNAME:-postgres}
      SPRING_DATASOURCE_PASSWORD: ${SPRING_DATASOURCE_PASSWORD:-postgres}
      SPRING_RABBITMQ_HOST: rabbitmq
      EUREKA_CLIENT_SERVICEURL_DEFAULTZONE: http://eureka-server:8761/eureka/
      EUREKA_INSTANCE_HOSTNAME: logique-metier-service
      JAVA_TOOL_OPTIONS: "-Dfile.encoding=UTF-8"
    volumes:
      - uploads_data:/app/uploads
    ports:
      - "8083:8083"
    restart: unless-stopped

  notification-service:
    build:
      context: ./backend
      dockerfile: ./notification-service/Dockerfile
    container_name: pfa-notification
    depends_on:
      rabbitmq:
        condition: service_healthy
      eureka-server:
        condition: service_healthy
    environment:
      SPRING_RABBITMQ_HOST: rabbitmq
      EUREKA_CLIENT_SERVICEURL_DEFAULTZONE: http://eureka-server:8761/eureka/
      EUREKA_INSTANCE_HOSTNAME: notification-service
      JAVA_TOOL_OPTIONS: "-Dfile.encoding=UTF-8"
      NOTIFICATION_MAIL_ENABLED: ${NOTIFICATION_MAIL_ENABLED:-false}
    ports:
      - "8085:8085"
    restart: unless-stopped

  chatbot-service:
    build: ./backend/chatbotIA
    container_name: pfa-chatbot
    depends_on:
      logique-metier-service:
        condition: service_started
      eureka-server:
        condition: service_healthy
    environment:
      LOGIQUE_METIER_URL: http://logique-metier-service:8083
      EUREKA_CLIENT_SERVICEURL_DEFAULTZONE: http://eureka-server:8761/eureka/
      EUREKA_INSTANCE_HOSTNAME: chatbot-service
      JAVA_TOOL_OPTIONS: "-Dfile.encoding=UTF-8"
    ports:
      - "8088:8088"
    restart: unless-stopped

  api-gateway:
    build: ./backend/api-gateway
    container_name: pfa-gateway
    depends_on:
      eureka-server:
        condition: service_healthy
      auth-service:
        condition: service_started
      logique-metier-service:
        condition: service_started
      chatbot-service:
        condition: service_started
    environment:
      EUREKA_CLIENT_SERVICEURL_DEFAULTZONE: http://eureka-server:8761/eureka/
      EUREKA_INSTANCE_HOSTNAME: api-gateway
      JAVA_TOOL_OPTIONS: "-Dfile.encoding=UTF-8"
      JWT_SECRET: ${JWT_SECRET:-9a4f2c8d3b7a1e5f8g6h4j2k0l9m8n7o6p5q4r3s2t1u0v9w8x7y6z5a4b3c2d1e}
    ports:
      - "8080:8080"
    restart: unless-stopped

  frontend:
    build: ./frontend
    container_name: pfa-frontend
    depends_on:
      api-gateway:
        condition: service_started
    ports:
      - "4200:80"
    restart: unless-stopped

volumes:
  postgres_data:
  uploads_data:

  jenkins:
    image: jenkins/jenkins:lts
    container_name: pfa-jenkins
    ports:
      - "8090:8080"
      - "50000:50000"
    volumes:
      - jenkins_home:/var/jenkins_home
      - //var/run/docker.sock:/var/run/docker.sock
    restart: unless-stopped
  jenkins_home:
